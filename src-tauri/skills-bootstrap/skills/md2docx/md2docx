#!/bin/bash
# md2docx skill wrapper — markdown → refined .docx via docx-js (docx npm).
#
# Usage:
#   ./md2docx <file.md> [more.md ...]
#   ./md2docx <file.md> -o <out.docx>
#   ./md2docx <file.md> --theme mineral|koica|mono   (default: mineral)
#   ./md2docx <file.md> --serif                       (Korean myeongjo body, formal)
#   ./md2docx <file.md> --header "Running header"      (override) | --no-header
#
# Resolves the Maru env Node runtime + sets NODE_PATH so the bundled `docx`
# package (~/.maru/env/node_modules) is importable. See skills/envs/default/REFERENCE.md.

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

# Resolve the Maru skills Node interpreter, most-specific first.
# Honors $SKILL_NODE, then host-injected $MARU_SKILLS_ENV, then the canonical
# ~/.maru/env/node (bundled), then a repo-local walk-up (dev-in-tree), then system node.
find_env_node() {
    local c dir
    if [ -n "${SKILL_NODE:-}" ] && [ -x "${SKILL_NODE}" ]; then
        printf '%s\n' "$SKILL_NODE"; return 0
    fi
    for c in \
        "${MARU_SKILLS_ENV:+$MARU_SKILLS_ENV/node/bin/node}" \
        "$HOME/.maru/env/node/bin/node"; do
        [ -n "$c" ] && [ -x "$c" ] && printf '%s\n' "$c" && return 0
    done
    dir="$SCRIPT_DIR"
    while [ "$dir" != "/" ]; do
        for c in \
            "$dir/env/node/bin/node" \
            "$dir/envs/default/node/bin/node" \
            "$dir/skills/envs/default/node/bin/node"; do
            [ -x "$c" ] && printf '%s\n' "$c" && return 0
        done
        dir="$(dirname "$dir")"
    done
    command -v node 2>/dev/null && return 0
    return 1
}

NODE_BIN="$(find_env_node || true)"
if [ -z "$NODE_BIN" ] || [ ! -x "$NODE_BIN" ]; then
    echo "[md2docx] node 없음. 'bash ~/.maru/skills/_builtin/envs/default/setup.sh --target ~/.maru/env' 실행" >&2
    exit 1
fi

# Resolve the env root from the bundled node (.../node/bin/node → env root) and
# export NODE_PATH so CJS `require("docx")` resolves the env-installed package.
# (ESM static import does NOT honor NODE_PATH; the converter uses createRequire.)
case "$NODE_BIN" in
    */node/bin/node)
        _ENV_ROOT="$(cd "$(dirname "$NODE_BIN")/../.." && pwd -P)"
        ;;
    *)
        _ENV_ROOT="${MARU_SKILLS_ENV:-$HOME/.maru/env}"
        echo "[md2docx] 번들 node 미발견, system node fallback: $NODE_BIN" >&2
        ;;
esac
if [ -d "$_ENV_ROOT/node_modules" ]; then
    case ":${NODE_PATH:-}:" in
        *":$_ENV_ROOT/node_modules:"*) ;;
        *) NODE_PATH="$_ENV_ROOT/node_modules${NODE_PATH:+:$NODE_PATH}"; export NODE_PATH;;
    esac
fi

if [ $# -eq 0 ]; then
    cat <<USAGE
md2docx — markdown → refined .docx (docx-js, pandoc 미사용)

Usage: ./md2docx <file.md> [more.md ...] [options]

Options:
  -o <out.docx>           단일 입력일 때 출력 경로 지정 (기본: 입력 .md 옆에 .docx)
  --theme mineral|koica|mono   팔레트 (기본 mineral; koica=네이비, mono=모노크롬)
  --serif                 한글 명조 본문 (격식 문서)
  --header "TEXT"         머리말 텍스트 override
  --no-header             머리말 제거

Features: YAML frontmatter, H1–H6(+부제), **bold**/_italic_/\`code\`/〔확인필요〕,
  링크, 표(정렬·라벨셀·zebra), 중첩 불릿/번호, 체크리스트, 인용, 코드블록, 구분선.
  폰트: 맑은 고딕(eastAsia) + Calibri/Cambria. 머리말=제목, 바닥글=PAGE.

런타임: Maru env 번들 Node + docx npm (NODE_PATH=~/.maru/env/node_modules).
경로 기준: ~/.maru/skills/md2docx/md2docx
USAGE
    exit 0
fi

exec "$NODE_BIN" "$SCRIPT_DIR/scripts/md2docx.mjs" "$@"
